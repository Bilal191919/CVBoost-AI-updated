# Gemini API Key (Required)
GEMINI_API_KEY=

# JazzCash Configuration (Required for payments)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_ENVIRONMENT=sandbox # or production

# Firebase Admin SDK (Optional, required for secure backend updates)
# Paste the entire JSON content of your service account key here
FIREBASE_SERVICE_ACCOUNT=
